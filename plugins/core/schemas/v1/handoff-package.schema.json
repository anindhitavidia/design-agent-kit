{
  "$id": "https://design-agent-kit/schemas/v1/handoff-package.schema.json",
  "title": "04-handoff/handoff-package.md frontmatter",
  "type": "object",
  "required": ["stage", "project", "component_specs", "a11y_report", "ready_for_engineering"],
  "properties": {
    "stage": { "const": 4 },
    "project": { "type": "string", "minLength": 1 },
    "component_specs": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "a11y_report": { "type": "string", "minLength": 1 },
    "ready_for_engineering": { "type": "boolean" },
    "screenshots_dir": { "type": "string" },
    "known_issues": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
